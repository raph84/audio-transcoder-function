# GCP project and region
PROJECT_ID=
REGION=

# Cloud Function / Eventarc trigger
FUNCTION_NAME=transcode-audio
TRIGGER_BUCKET=

# Runtime service account (used by the function's code to read/write GCS)
SERVICE_ACCOUNT=

# Function runtime tuning
MEMORY=1GiB
# 300s is fine when SPLIT_AFTER_MINUTES is unset. If splitting is enabled,
# the whole invocation (probe + transcode + silencedetect + all concurrent
# part uploads) must fit in one timeout, so consider raising this for long
# recordings (Gen2 supports up to 3600s).
TIMEOUT=300s

# Application env vars (see src/config.js)
SOURCE_PREFIX=source/
OUTPUT_PREFIX=transcoded/
OUTPUT_FORMAT=flac
OUTPUT_BUCKET=

# Splitting (optional; unset disables the feature entirely). Recordings
# longer than SPLIT_AFTER_MINUTES also get cut into silence-aware parts
# alongside the full FLAC output. Requires granting the runtime service
# account roles/iam.serviceAccountTokenCreator on itself — see
# DEVELOPMENT.md.
SPLIT_AFTER_MINUTES=
SILENCE_NOISE_DB=-30
SILENCE_MIN_DURATION_SECONDS=0.5
# Blank = auto-computed (25% of the split interval, capped at 120s)
SILENCE_LOOKBACK_MAX_SECONDS=
