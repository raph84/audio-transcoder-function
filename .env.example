# GCP project and region
PROJECT_ID=
REGION=

# Cloud Function / Eventarc trigger
FUNCTION_NAME=transcode-audio
TRIGGER_BUCKET=

# Runtime service account (used by the function's code to read/write GCS)
SERVICE_ACCOUNT=

# Function runtime tuning
MEMORY=1GiB
TIMEOUT=300s

# Application env vars (see src/config.js)
SOURCE_PREFIX=source/
OUTPUT_PREFIX=transcoded/
OUTPUT_FORMAT=flac
OUTPUT_BUCKET=
