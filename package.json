{
	"name": "audio-transcoder-function",
	"version": "1.0.0",
	"description": "GCP Cloud Function: M4A to FLAC audio transcoder via GCS trigger",
	"main": "index.js",
	"type": "module",
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"start": "functions-framework --target=transcodeAudio --signature-type=cloudevent",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"check": "biome check --write .",
		"test": "vitest run",
		"prepare": "husky"
	},
	"keywords": [],
	"author": "raph.berube@gmail.com",
	"license": "Apache-2.0",
	"packageManager": "pnpm@10.32.1",
	"pnpm": {
		"onlyBuiltDependencies": [
			"@ffprobe-installer/ffprobe",
			"ffmpeg-static"
		]
	},
	"lint-staged": {
		"*": "biome check --write --no-errors-on-unmatched"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.1",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@ffprobe-installer/ffprobe": "^2.1.2",
		"@google-cloud/functions-framework": "^5.0.2",
		"@google-cloud/storage": "^7.21.0",
		"ffmpeg-static": "^5.3.0",
		"fluent-ffmpeg": "^2.1.3"
	}
}
